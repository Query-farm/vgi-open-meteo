# name: test/sql/open_meteo_catalog.test
# description: Catalog discovery, ATTACH (incl. apikey option), and function listing for the Open-Meteo worker
# group: [vgi_open_meteo]

require-env VGI_OPEN_METEO_WORKER

require vgi

require httpfs

# ============================================================================
# Catalog discovery
# ============================================================================

# Worker should expose the "open_meteo" catalog
query I
SELECT catalog FROM vgi_catalogs('${VGI_OPEN_METEO_WORKER}');
----
open_meteo

# The optional `apikey` ATTACH option should be advertised
query I
SELECT len(attach_options) FROM vgi_catalogs('${VGI_OPEN_METEO_WORKER}');
----
1

query I
SELECT attach_options[1].name FROM vgi_catalogs('${VGI_OPEN_METEO_WORKER}');
----
apikey

# ============================================================================
# ATTACH and schema discovery
# ============================================================================

statement ok
ATTACH 'open_meteo' AS open_meteo (TYPE vgi, LOCATION '${VGI_OPEN_METEO_WORKER}');

# Should have a "main" schema
query II
SELECT catalog_name, schema_name FROM information_schema.schemata WHERE catalog_name = 'open_meteo';
----
open_meteo	main

# ============================================================================
# Function discovery — 13 weather table functions (every one requires
# coordinates / a search name, so there are no zero-arg catalog tables) plus 6
# scalar decoding macros (weather_code / wind / AQI / UV → labels).
# ============================================================================

query I rowsort
SELECT DISTINCT function_name FROM duckdb_functions() WHERE database_name = 'open_meteo';
----
air_quality_current
air_quality_hourly
climate_daily
elevation
european_aqi_category
flood_daily
forecast_current
forecast_daily
forecast_hourly
geocoding
historical_daily
historical_hourly
marine_daily
marine_hourly
us_aqi_category
uv_index_category
weather_code_emoji
weather_code_text
wind_compass

# The decoding macros are pure SQL (no RPC) and deterministic, so assert their
# labels directly.
query TTTT
SELECT open_meteo.main.weather_code_text(61),
       open_meteo.main.wind_compass(315),
       open_meteo.main.us_aqi_category(120),
       open_meteo.main.uv_index_category(9);
----
Slight rain	NW	Unhealthy for Sensitive Groups	Very High

# The weather_codes view is a browsable, no-argument reference relation (the
# WMO 4677 table). It backs the weather_code_* macros and is JOINable.
query ITT
SELECT code, description, emoji FROM open_meteo.main.weather_codes WHERE code IN (0, 95) ORDER BY code;
----
0	Clear sky	☀️
95	Thunderstorm	⛈️

query I
SELECT count(*) FROM open_meteo.main.weather_codes;
----
28

statement ok
DETACH open_meteo;

# ============================================================================
# ATTACH with an apikey option must be accepted (validated + cast by the
# extension). We do NOT run a weather query here: a key routes every request to
# the commercial customer-* hosts, which reject a non-real key.
# ============================================================================

statement ok
ATTACH 'open_meteo' AS open_meteo_keyed (TYPE vgi, LOCATION '${VGI_OPEN_METEO_WORKER}', apikey 'test-key');

query II
SELECT catalog_name, schema_name FROM information_schema.schemata WHERE catalog_name = 'open_meteo_keyed';
----
open_meteo_keyed	main

statement ok
DETACH open_meteo_keyed;
